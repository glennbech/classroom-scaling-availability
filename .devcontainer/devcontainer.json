{
  "name": "Terraform AWS CLI Docker",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "postCreateCommand": "terraform --version && aws --version && docker --version",
  "remoteUser": "vscode"
}
